<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kernel Panic Inc.</title>
    <style>
        /* Modern Reset and Typography */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f4f6f9;
            color: #333;
            line-height: 1.6;
        }

        /* Navigation Bar */
        header {
            background-color: #1a1a2e;
            color: #ffffff;
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #00adb5;
        }

        .nav-links {
            list-style: none;
            display: flex;
            gap: 2rem;
        }

        .nav-links a {
            color: #fff;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #00adb5;
        }

        /* Main Container */
        main {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #1f4068, #162447);
            color: white;
            padding: 4rem 2rem;
            border-radius: 8px;
            text-align: center;
            margin-bottom: 2rem;
        }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
            color: #e2e2e2;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Content Grid */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .card h3 {
            color: #1f4068;
            margin-bottom: 0.5rem;
        }

        /* Contact Form Section */
        .contact-section {
            background: white;
            padding: 2.5rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            max-width: 600px;
            margin: 0 auto;
        }

        .contact-section h2 {
            margin-bottom: 1.5rem;
            color: #1f4068;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .form-group input, .form-group textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 1rem;
        }

        .form-group input:focus, .form-group textarea:focus {
            outline: none;
            border-color: #00adb5;
        }

        button {
            background-color: #00adb5;
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            font-size: 1rem;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
            font-weight: bold;
            transition: background 0.3s;
        }

        button:hover {
            background-color: #008c9e;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 2rem;
            background-color: #1a1a2e;
            color: #888;
            margin-top: 4rem;
        }
    </style>
</head>
<body>

    <!-- Navigation Header -->
    <header>
        <nav>
            <div class="logo">Kernel Panic Inc.</div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Main Content Area -->
    <main>
        <!-- Hero Section -->
        <section class="hero" id="home">
            <h1>Welcome to Kernel Panic Inc.</h1>
            <p>Providing high-performance, robust tech solutions for complex digital environments.</p>
        </section>

        <!-- Services Section -->
        <section class="services-grid" id="services">
            <div class="card">
                <h3>Systems Architecture</h3>
                <p>We design stable, scalable infrastructure setups tailored specifically to handle extreme user loads smoothly.</p>
            </div>
            <div class="card">
                <h3>Cloud Integration</h3>
                <p>Easily move your workflows over to fully secure systems optimized for maximum operational uptime.</p>
            </div>
            <div class="card">
                <h3>Performance Audits</h3>
                <p>We find bottlenecks deep in application codebases to prevent random crashes or system freezes.</p>
            </div>
        </section>

        <!-- Contact Form Section -->
        <section class="contact-section" id="contact">
            <h2>Get in Touch</h2>
            <form action="#" method="POST" onsubmit="alert('Form submission is a demo!'); return false;">
                <div class="form-group">
                    <label for="name">Your Name</label>
                    <input type="text" id="name" required placeholder="John Doe">
                </div>
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" required placeholder="john@example.com">
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" rows="5" required placeholder="How can we help your business?"></textarea>
                </div>
                <button type="submit">Send Message</button>
            </form>
        </section>
    </main>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Kernel Panic Inc. All rights reserved.</p>
    </footer>

</body>
</html>
